{
  "name": "JupyterLab: Codex ACP",
  "build": {
    "dockerfile": "codex/Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--cpus=4",
    "--memory=8g"
  ],
  // "remoteUser": "root",
  // Jupyter always listens on 8888 inside the container (it's the only
  // thing in here, so that's always free). The host-side mapping is
  // flexible: requireLocalPort=false lets VS Code pick a free local
  // port whenever 8888 is busy on the host (e.g. Apple Container, or a
  // sibling devcontainer).
  "forwardPorts": [
    8888
  ],
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "requireLocalPort": false,
      // `openBrowser` re-fires whenever VS Code re-detects the forward
      // (e.g. a Jupyter URL printed by `ps aux`, `jupyter notebook
      // list`, `curl localhost:8888`, or a Ctrl-C restart), which can
      // open a dozen tabs in a single Codex session. `notify` lets us
      // click through once and keeps the cascade off.
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "GOOGLE_API_KEY": "${localEnv:GOOGLE_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "DEEPSEEK_API_KEY": "${localEnv:DEEPSEEK_API_KEY}"
  },
  "secrets": {
    "GOOGLE_API_KEY": {
      "description": "Your Google API key for accessing Google services in ACP.",
      "documentationUrl": "https://docs.github.com/en/codespaces/managing-your-codespaces/managing-your-account-specific-secrets-for-github-codespaces"
    },
    "OPENAI_API_KEY": {
      "description": "Your OpenAI API key for accessing OpenAI services in ACP.",
      "documentationUrl": "https://docs.github.com/en/codespaces/managing-your-codespaces/managing-your-account-specific-secrets-for-github-codespaces"
    },
    "DEEPSEEK_API_KEY": {
      "description": "Your DeepSeek API key for accessing DeepSeek services in ACP.",
      "documentationUrl": "https://docs.github.com/en/codespaces/managing-your-codespaces/managing-your-account-specific-secrets-for-github-codespaces"
    }
  },
  "containerEnv": {
    "JUPYTER_PORT": "8888",
    "GRANT_SUDO": "no",
    "ACP_AGENT_COMMAND": "/home/jovyan/.local/bin/codex-acp",
    "ACP_AGENT_ARGS": "",
    "RESTARTABLE": "yes"
  },
  // The LM Studio request shim (workaround for LM Studio bug-tracker
  // #1810/#1812, where the Responses endpoint rejects Codex 0.130+
  // "namespace" MCP tool envelopes) is started by start.sh via the
  // before-notebook.d hook installed by codex/Dockerfile, so it's up
  // before any agent (kernel-spawned, codex-acp, or shell codex) needs
  // it. The kernel also calls ensure_running() defensively at agent
  // launch in case the hook didn't fire.
  // To disable: ACP_LMSTUDIO_SHIM=off. To override upstream:
  // HOST_GATEWAY_IP=... or ACP_LMSTUDIO_SHIM_TARGET=...
  //
  // Codespaces ports are private by default so skip the auth token.
  // Need to disable XSRF check for Jupyter MCP servers if auth token is disabled.
  // start.sh runs the before-notebook.d hooks (including the LM Studio
  // shim) and then launches Jupyter Lab. `--no-browser` keeps Jupyter
  // itself from invoking webbrowser.open() (which in a devcontainer
  // goes through VS Code's URL handler and opens a host tab every
  // restart).
  // --ServerApp.cookie_secret_file pins the HMAC secret used to sign
  // login cookies to a path under $HOME (which is a mounted volume), so
  // the secret survives container rebuilds. Without this Jupyter
  // regenerates a random secret each start, invalidating every cookie
  // the VS Code Jupyter extension / Simple Browser / system browser
  // cached from the previous run — which shows up as a flood of
  // "Clearing invalid/expired login cookie" warnings on each request.
  "postStartCommand": "nohup start.sh jupyter lab --no-browser --IdentityProvider.token='' --ServerApp.disable_check_xsrf=True --ServerApp.cookie_secret_file=/home/jovyan/.jupyter/cookie_secret > /tmp/jupyter.log 2>&1 &"
}